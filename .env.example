# Vercel/Neon runtime connection. `pnpm dev` supplies its local URL itself.
DATABASE_URL=

# Optional override for the dedicated Docker database used by `pnpm dev`.
LOCAL_DATABASE_URL=postgresql://history_wall:history_wall@127.0.0.1:54329/history_wall

# Optional AI event images. `auto` prefers Gemini when both keys exist.
IMAGE_PROVIDER=gemini
IMAGE_GENERATION_SECRET=replace-with-a-long-random-secret
GEMINI_API_KEY=
OPENAI_API_KEY=

# Provider defaults are cost-oriented and can be overridden without code edits.
GEMINI_IMAGE_MODEL=gemini-3.1-flash-lite-image
OPENAI_IMAGE_MODEL=gpt-image-1-mini
